{
  "name": "koe-api",
  "main": "src/index.ts",
  "compatibility_date": "2025-04-01",

  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "koe-db",
      "database_id": "placeholder",
      "migrations_dir": "../../db/migrations",
    },
  ],

  "r2_buckets": [
    {
      "binding": "BUCKET",
      "bucket_name": "koe-storage",
    },
  ],
}
